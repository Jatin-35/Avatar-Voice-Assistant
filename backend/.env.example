# ── Azure OpenAI (LLM) ─────────────────────────────────────────────────────
# Required for LLM responses. Get from Azure Portal > Azure OpenAI > Keys.
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# ── Azure Speech (TTS) ─────────────────────────────────────────────────────
# Required for Text-to-Speech. Get from Azure Portal > Speech > Keys.
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# ── TTS Voice ──────────────────────────────────────────────────────────────
# Azure Neural TTS voice name and language tag.
TTS_VOICE_NAME=hi-IN-AartiNeural
TTS_VOICE_LANGUAGE=hi-IN

# ── Deepgram STT ───────────────────────────────────────────────────────────
# Required for Speech-to-Text. Get from https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Server ─────────────────────────────────────────────────────────────────
# Port for the FastAPI backend (default 8000).
BACKEND_PORT=8000

# Allowed CORS origins (comma-separated). Vite dev server runs on 5173.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ── RAG / Knowledge Base ────────────────────────────────────────────────────
# Knowledge base lives in backend/knowledge_base/ (separate from phone bot's KB).
# Build index: python backend/scripts/build_index.py
# Force rebuild: FORCE_REBUILD_INDEX=1 python backend/scripts/build_index.py

# Optional: override KB path (default: backend/knowledge_base/)
# KB_DIR=/absolute/path/to/your/knowledge_base

# Retrieval tuning (defaults are good for most use cases)
RAG_TOP_K=6                # chunks injected into LLM per query
RAG_MAX_CONTEXT_CHARS=2500 # max total context length
RAG_FETCH_PER_LIST=36      # candidates from FAISS + BM25 each before RRF fusion
RAG_RRF_K=60               # RRF constant (higher = less rank-position bias)
USE_RERANKER=false          # set true to enable cross-encoder reranker (~3s extra latency)
