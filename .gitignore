# ── Secrets ──────────────────────────────────────────────────────────────────
# Real keys live in .env (never commit). .env.example is the safe template.
.env
*.env
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# ── RAG index (regenerated by backend/scripts/build_index.py) ────────────────
backend/knowledge_base/faiss_index/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── Avatar GIF backups (local-only restore points) ───────────────────────────
*.orig.gif

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
